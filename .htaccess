php_value upload_max_filesize 50M
php_value post_max_size 50M
php_value memory_limit 512M
php_value max_execution_time 600
php_value max_input_time 600

RewriteEngine On

# --- Route all non-file requests to index.php (no redirect) ---
FallbackResource /index.php

# --- Block sensitive directories (return 404) ---
RewriteRule ^(config|controllers|models|views|lang|handlers|helpers|database|caddy|docker|app-icons|secrets|local|\.git)/ - [R=404,L]

# --- Block uploads/dumps (backup files) ---
RewriteRule ^uploads/dumps/ - [R=404,L]

# --- Block specific sensitive files ---
RewriteRule ^\.env - [R=404,L]
RewriteRule \.(md|MD)$ - [R=404,L]
RewriteRule ^Dockerfile$ - [R=404,L]
RewriteRule ^docker-compose - [R=404,L]
RewriteRule ^\.((?!htaccess).)+$ - [R=404,L]
