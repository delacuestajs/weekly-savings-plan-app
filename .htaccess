php_value upload_max_filesize 50M
php_value post_max_size 50M
php_value memory_limit 512M
php_value max_execution_time 600
php_value max_input_time 600

# Block .env files
<FilesMatch "^\.env">
    Require all denied
</FilesMatch>

# Block markdown files
<FilesMatch "\.(md|MD)$">
    Require all denied
</FilesMatch>

# Block Dockerfile
<Files "Dockerfile">
    Require all denied
</Files>

# Block docker-compose files
<FilesMatch "^docker-compose">
    Require all denied
</FilesMatch>

# Block other dotfiles (except .htaccess)
<FilesMatch "^\.((?!htaccess).)+$">
    Require all denied
</FilesMatch>
