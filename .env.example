# ===========================================
# Environment Variables Configuration
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control!
# ===========================================

# ----- Remote server SSH -----
SSH_HOST=your_server_ip
SSH_USER=your_ssh_user
SSH_PASS=your_ssh_password
SSH_DIR=/opt/oc-test-php

# ----- Caddy (Reverse Proxy) -----
# Your domain or DDNS hostname for HTTPS
CADDY_DOMAIN=your-domain.com

# ----- Application -----
# Port for local LAN access (different from .env)
APP_PORT=8080

# ----- Database (MySQL) -----
# Database host (use 'db' for Docker, 'localhost' for local)
DB_HOST=db

# Database name
DB_NAME=savings_db

# Database user credentials (different from .env)
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# MySQL root password (for initial setup)
DB_ROOT_PASSWORD=your_root_password

# ----- Payment System -----
DEFAULT_FIXED_AMOUNT=50000

# ----- SMTP (MSMTP) -----
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=your_email@example.com

# ----- Email Notifications -----
# Set to 'no' to disable all email notifications
EMAIL_NOTIFICATIONS_ENABLED=yes
